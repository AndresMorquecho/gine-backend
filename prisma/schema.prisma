generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id                String   @id @default(uuid())
  nombres           String
  apellidos         String
  tipoDocumento     String   @default("DNI")
  numeroDocumento   String   @unique
  fechaNacimiento   DateTime
  estadoCivil       String   @default("Soltera")
  ocupacion         String?
  telefono          String?
  email             String?
  direccion         String?
  ciudad            String?
  contactoEmergencia String?
  telefonoEmergencia String?
  tipoSanguineo     String?
  alergias          String?
  antecedentes      String?
  seguroMedico      String?
  menarquia         String?
  metodoAnticonceptivo String?
  vidaSexualActiva  String   @default("No")
  gestas            Int      @default(0)
  partos            Int      @default(0)
  cesareas          Int      @default(0)
  abortos           Int      @default(0)
  fechaRegistro     DateTime @default(now())
  observaciones     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  consultations     Consultation[]
  medicalOrders     MedicalOrder[]

  @@map("patients")
}

model Consultation {
  id              String   @id @default(uuid())
  patientId       String
  doctorId        String   @default("default-doctor")
  date            DateTime @default(now())
  type            String   @default("Consulta Ginecología")
  reason          String?
  evolution       String?
  
  vitalSigns      ConsultationVitalSigns?
  gynecology      ConsultationGynecology?
  treatment       ConsultationTreatment?
  
  diagnoses       ConsultationDiagnosis[]
  documents       ConsultationDocument[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("consultations")
}

model ConsultationVitalSigns {
  id              String   @id @default(uuid())
  consultationId  String   @unique
  weight          String?
  height          String?
  pressure        String?
  heartRate       String?
  respRate        String?
  temp            String?
  saturacion      String?
  bmi             String?
  
  alturaUterina   String?
  fcf             String?
  movFetales      String?
  edema           String?
  contracciones   String?

  consultation    Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  @@map("consultation_vital_signs")
}

model ConsultationGynecology {
  id                String   @id @default(uuid())
  consultationId    String   @unique
  
  fum               DateTime?
  fpp               DateTime?
  eg                String?
  ciclo             Int      @default(28)
  duracion          Int      @default(5)
  regularidad       String   @default("Regular")
  metodo            String?
  vidaSexualActiva  Boolean  @default(true)
  sintomasMenstruales String?

  gestas            Int      @default(0)
  partos            Int      @default(0)
  cesareas          Int      @default(0)
  abortos           Int      @default(0)
  hijosVivos        Int      @default(0)
  ectopicos         Int      @default(0)
  fechaUltimoParto  DateTime?

  papUltimo         DateTime?
  papResultado      String?
  colposcopia       String?
  itsPrevias        String?
  cirugiasGine      String?
  endometriosis     Boolean  @default(false)
  sop               Boolean  @default(false)
  miomatosis        Boolean  @default(false)
  quistes           Boolean  @default(false)

  dolorPelvico      Boolean  @default(false)
  dismenorrea       Boolean  @default(false)
  sangradoIrregular Boolean  @default(false)
  leucorrea         Boolean  @default(false)
  mastalgia         Boolean  @default(false)
  amenorrea         Boolean  @default(false)

  observaciones     String?

  consultation    Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  @@map("consultation_gynecology")
}

model ConsultationDiagnosis {
  id              String   @id @default(uuid())
  consultationId  String
  code            String?
  description     String
  isPrimary       Boolean  @default(true)

  consultation    Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  @@map("consultation_diagnoses")
}

model ConsultationTreatment {
  id              String   @id @default(uuid())
  consultationId  String   @unique
  plan            String?
  followUp        String?

  consultation    Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  @@map("consultation_treatments")
}

model ConsultationDocument {
  id              String   @id @default(uuid())
  consultationId  String
  name            String
  url             String
  type            String
  createdAt       DateTime @default(now())

  consultation    Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  @@map("consultation_documents")
}

// ==========================================
// MÓDULO DE ÓRDENES Y EXÁMENES (PRO)
// ==========================================

model OrderType {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  description   String?
  icon          String?
  color         String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  categories    ExamCategory[]
  orders        MedicalOrder[]

  @@map("order_types")
}

model ExamCategory {
  id            String   @id @default(uuid())
  orderTypeId   String
  name          String
  description   String?
  color         String?
  icon          String?
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  orderType     OrderType @relation(fields: [orderTypeId], references: [id], onDelete: Cascade)
  exams         MedicalExam[]

  @@map("exam_categories")
}

model SampleType {
  id            String   @id @default(uuid())
  name          String
  description   String?

  exams         MedicalExam[]

  @@map("sample_types")
}

model ExamPreparation {
  id            String   @id @default(uuid())
  title         String
  content       String
  active        Boolean  @default(true)

  exams         MedicalExam[] @relation("ExamToPreparation")

  @@map("exam_preparations")
}

model MedicalExam {
  id              String   @id @default(uuid())
  categoryId      String
  sampleTypeId    String?
  name            String
  code            String?
  description     String?
  preparation     String?
  recommendations String?
  normalRange     String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category        ExamCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  sampleType      SampleType?  @relation(fields: [sampleTypeId], references: [id])
  preparations    ExamPreparation[] @relation("ExamToPreparation")
  orderItems      MedicalOrderItem[]

  @@map("medical_exams")
}

model MedicalOrder {
  id              String   @id @default(uuid())
  patientId       String
  orderTypeId     String
  consultationId  String?
  doctorId        String   @default("default-doctor")
  secuencial      String   @unique
  date            DateTime @default(now())
  status          String   @default("Pendiente")
  priority        String   @default("Normal")
  observations    String?
  diagnosis       String?

  patient         Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  orderType       OrderType    @relation(fields: [orderTypeId], references: [id])
  items           MedicalOrderItem[]
  results         OrderResult[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("medical_orders")
}

model OrderResult {
  id        String   @id @default(uuid())
  orderId   String
  url       String
  filename  String
  fileType  String
  createdAt DateTime @default(now())

  order     MedicalOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_results")
}

model MedicalOrderItem {
  id              String   @id @default(uuid())
  orderId         String
  examId          String
  status          String   @default("Pendiente")
  resultUrl       String?
  observations    String?

  order           MedicalOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  exam            MedicalExam  @relation(fields: [examId], references: [id])

  @@map("medical_order_items")
}
