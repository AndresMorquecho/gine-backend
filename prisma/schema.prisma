generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// PACIENTES
// ==========================================

model Patient {
  id                   String   @id @default(uuid())
  nombres              String
  apellidos            String
  tipoDocumento        String   @default("DNI")
  numeroDocumento      String   @unique
  fechaNacimiento      DateTime?
  estadoCivil          String   @default("Soltera")
  ocupacion            String?
  telefono             String?
  email                String?
  direccion            String?
  ciudad               String?
  contactoEmergencia   String?
  telefonoEmergencia   String?
  tipoSanguineo        String?
  alergias             String?
  antecedentes         String?
  seguroMedico         String?
  menarquia            String?
  metodoAnticonceptivo String?
  vidaSexualActiva     String   @default("No")
  fechaRegistro        DateTime @default(now())
  observaciones        String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  consultations        Consultation[]
  medicalOrders        MedicalOrder[]
  pregnancies          Pregnancy[]

  @@map("patients")
}

// ==========================================
// EMBARAZOS (Entidad longitudinal central)
// ==========================================

model Pregnancy {
  id            String    @id @default(uuid())
  patientId     String
  fum           DateTime
  fpp           DateTime  // Calculado automáticamente (Regla de Naegele)
  egInitial     Float?    // Semanas gestacionales al inicio
  initialWeight Float?    // kg
  initialHeight Float?    // cm
  initialImc    Float?    // Calculado: weight/(height/100)^2

  bloodType     String?
  rh            String?

  // Riesgo obstétrico acumulado
  riskScore     Int     @default(0)
  riskLevel     String  @default("sin_riesgo") // sin_riesgo | bajo | alto | muy_alto

  // Estado del embarazo
  status        String  @default("activo") // activo | cerrado | perdido | ectopico

  notes         String?
  createdAt     DateTime  @default(now())
  closedAt      DateTime?

  patient        Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  controls       PrenatalControl[]
  risks          PregnancyRisk[]
  echographies   PregnancyEchography[]

  @@map("pregnancies")
}

// ==========================================
// CONTROLES PRENATALES
// ==========================================

model PrenatalControl {
  id             String   @id @default(uuid())
  pregnancyId    String
  controlDate    DateTime @default(now())
  gestationalAge Float    // Semanas (ej: 24.2)
  maternalWeight Float?   // kg
  bloodPressure  String?  // "110/70"
  temperature    Float?   // °C
  fetalHeartRate Int?     // lpm (FCF)
  uterineHeight  Int?     // cm (AU)
  edema          String?  // "Ausente" | "+" | "++" | "+++"
  fetalMovements String?  // "Presentes" | "Disminuidos" | "Ausentes"
  contractions   String?  // "Ausentes" | "Irregulares" | "Regulares"
  observations   String?
  plan           String?
  createdAt      DateTime @default(now())

  pregnancy      Pregnancy @relation(fields: [pregnancyId], references: [id], onDelete: Cascade)

  @@map("prenatal_controls")
}

// ==========================================
// RIESGOS OBSTÉTRICOS
// ==========================================

model PregnancyRisk {
  id          String   @id @default(uuid())
  pregnancyId String
  riskName    String
  riskScore   Int      @default(1)
  notes       String?
  createdAt   DateTime @default(now())

  pregnancy   Pregnancy @relation(fields: [pregnancyId], references: [id], onDelete: Cascade)

  @@map("pregnancy_risks")
}

// ==========================================
// ECOGRAFÍAS OBSTÉTRICAS
// ==========================================

model PregnancyEchography {
  id             String   @id @default(uuid())
  pregnancyId    String
  studyDate      DateTime
  studyType      String   // morfologica | tamizaje | doppler | biofisico | transvaginal
  gestationalAge Float?   // semanas al momento del estudio
  studyName      String
  report         String?  // texto del informe
  doctorName     String?
  pdfUrl         String?
  images         String[] // array de URLs
  createdAt      DateTime @default(now())

  pregnancy      Pregnancy @relation(fields: [pregnancyId], references: [id], onDelete: Cascade)

  @@map("pregnancy_echographies")
}

// ==========================================
// CONSULTAS GINECOLÓGICAS GENERALES
// ==========================================

model Consultation {
  id         String   @id @default(uuid())
  patientId  String
  doctorId   String   @default("default-doctor")
  date       DateTime @default(now())
  type       String   @default("Consulta Ginecología")
  reason     String?
  evolution  String?

  vitalSigns ConsultationVitalSigns?
  gynecology ConsultationGynecology?
  treatment  ConsultationTreatment?

  diagnoses  ConsultationDiagnosis[]
  documents  ConsultationDocument[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, date(sort: Desc)])
  @@index([date(sort: Desc)])
  @@map("consultations")
}

// Signos vitales maternos (SIN campos fetales — esos van en PrenatalControl)
model ConsultationVitalSigns {
  id             String  @id @default(uuid())
  consultationId String  @unique
  weight         String?
  height         String?
  pressure       String?
  heartRate      String?
  respRate       String?
  temp           String?
  saturacion     String?
  bmi            String?

  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@map("consultation_vital_signs")
}

// Ginecología pura (SIN campos obstétricos longitudinales — esos van en Pregnancy)
model ConsultationGynecology {
  id                String   @id @default(uuid())
  consultationId    String   @unique

  // Ciclo menstrual
  ciclo             Int      @default(28)
  duracion          Int      @default(5)
  regularidad       String   @default("Regular")
  metodo            String?
  vidaSexualActiva  Boolean  @default(true)
  sintomasMenstruales String?

  // FUM de referencia para esta consulta (puede diferir del embarazo activo)
  fum               DateTime?
  fpp               DateTime? // Solo para consultas sin embarazo registrado
  eg                String?   // Solo para referencia rápida

  // Antecedentes ginecológicos
  papUltimo         DateTime?
  papResultado      String?
  colposcopia       String?
  itsPrevias        String?
  cirugiasGine      String?
  endometriosis     Boolean  @default(false)
  sop               Boolean  @default(false)
  miomatosis        Boolean  @default(false)
  quistes           Boolean  @default(false)

  // Síntomas del día
  dolorPelvico      Boolean  @default(false)
  dismenorrea       Boolean  @default(false)
  sangradoIrregular Boolean  @default(false)
  leucorrea         Boolean  @default(false)
  mastalgia         Boolean  @default(false)
  amenorrea         Boolean  @default(false)

  observaciones     String?

  consultation      Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@map("consultation_gynecology")
}

model ConsultationDiagnosis {
  id             String  @id @default(uuid())
  consultationId String
  code           String?
  description    String
  isPrimary      Boolean @default(true)

  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@index([consultationId])
  @@map("consultation_diagnoses")
}

model ConsultationTreatment {
  id             String  @id @default(uuid())
  consultationId String  @unique
  plan           String?
  followUp       String?

  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@map("consultation_treatments")
}

model ConsultationDocument {
  id             String   @id @default(uuid())
  consultationId String
  name           String
  url            String
  type           String
  createdAt      DateTime @default(now())

  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@index([consultationId])
  @@map("consultation_documents")
}

// ==========================================
// MÓDULO DE ÓRDENES Y EXÁMENES
// ==========================================

model OrderType {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  color       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  categories  ExamCategory[]
  orders      MedicalOrder[]

  @@map("order_types")
}

model ExamCategory {
  id          String   @id @default(uuid())
  orderTypeId String
  name        String
  description String?
  color       String?
  icon        String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  orderType   OrderType    @relation(fields: [orderTypeId], references: [id], onDelete: Cascade)
  exams       MedicalExam[]

  @@map("exam_categories")
}

model SampleType {
  id          String   @id @default(uuid())
  name        String
  description String?

  exams       MedicalExam[]

  @@map("sample_types")
}

model ExamPreparation {
  id      String   @id @default(uuid())
  title   String
  content String
  active  Boolean  @default(true)

  exams   MedicalExam[] @relation("ExamToPreparation")

  @@map("exam_preparations")
}

model MedicalExam {
  id              String   @id @default(uuid())
  categoryId      String
  sampleTypeId    String?
  name            String
  code            String?
  description     String?
  preparation     String?
  recommendations String?
  normalRange     String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category        ExamCategory      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  sampleType      SampleType?       @relation(fields: [sampleTypeId], references: [id])
  preparations    ExamPreparation[] @relation("ExamToPreparation")
  orderItems      MedicalOrderItem[]

  @@map("medical_exams")
}

model MedicalOrder {
  id            String   @id @default(uuid())
  patientId     String
  orderTypeId   String
  consultationId String?
  doctorId      String   @default("default-doctor")
  secuencial    String   @unique
  date          DateTime @default(now())
  status        String   @default("Pendiente")
  priority      String   @default("Normal")
  observations  String?
  diagnosis     String?

  patient       Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  orderType     OrderType        @relation(fields: [orderTypeId], references: [id])
  items         MedicalOrderItem[]
  results       OrderResult[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([patientId, date(sort: Desc)])
  @@index([consultationId])
  @@index([status])
  @@map("medical_orders")
}

model OrderResult {
  id        String   @id @default(uuid())
  orderId   String
  url       String
  filename  String
  fileType  String
  createdAt DateTime @default(now())

  order     MedicalOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_results")
}

model MedicalOrderItem {
  id           String  @id @default(uuid())
  orderId      String
  examId       String
  status       String  @default("Pendiente")
  resultUrl    String?
  observations String?

  order        MedicalOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  exam         MedicalExam  @relation(fields: [examId], references: [id])

  @@map("medical_order_items")
}

// ==========================================
// CONFIGURACIÓN DE CLÍNICA (singleton)
// ==========================================

model BusinessSettings {
  id                        String   @id @default("default")
  clinicName                String?
  taxId                     String?
  address                   String?
  phone                     String?
  email                     String?
  logoUrl                   String?  @db.Text
  reportHeader              String?  @db.Text
  reportFooter              String?  @db.Text
  billingSeries             String?
  billingNextNumber         Int      @default(1)
  currency                  String   @default("USD")
  recipeDoctorName          String?
  recipeDoctorSpecialty     String?
  recipeDoctorAcess         String?
  recipeDefaultCity         String?
  recipeDefaultAllergies    String?
  recipeDefaultValidityDays String?
  recipeLogoUrl             String?  @db.Text
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@map("business_settings")
}

// Landing pública: marca, hero, servicios, CTA, pie (JSON)
model SiteSettings {
  id        String   @id @default("default")
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ==========================================
// MEDICAMENTOS Y CONFIGURACIONES DE RECETA
// ==========================================

model Medicine {
  id               String   @id @default(uuid())
  genericName      String   @unique
  brandNames       String[]
  presentations    String[]
  concentrations   String[]
  defaultDose      String?
  defaultFrequency String?
  defaultDuration  String?
  defaultRoute     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("medicines")
}

model Prescription {
  id              String   @id @default(uuid())
  secuencial      String   @unique
  date            String
  patientId       String
  patientName     String
  medicinesCount  Int
  status          String   @default("Emitida") // Emitida | Vencida | Anulada
  medicines       Json     // Store full list of medicines as JSON
  vigencia        String?
  vigenciaTipo    String?
  diagnostico     String?
  cie10           String?
  alergias        String?
  doctor          Json?    // Store doctor details as JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("prescriptions")
}

model Appointment {
  id          String   @id @default(uuid())
  date        String   // YYYY-MM-DD
  time        String   // HH:MM
  patientName String
  patientAge  String
  doctorName  String
  reason      String
  type        String   // Control | Ecografía | Ginecología | Consulta | etc.
  status      String   @default("Agendada") // Agendada | Confirmada | Sala de espera | En consultorio | En atención | Finalizada | Cancelada | No asistió
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date, status])
  @@map("appointments")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  nombres   String?
  apellidos String?
  status    String   @default("Activo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}


